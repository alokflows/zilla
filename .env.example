# ============================================================
#  Zilla Bot — Configuration TEMPLATE
# ============================================================
#  HOW TO USE:
#    1. Make a copy of this file and name the copy ".env"
#    2. Fill in the two REQUIRED values below
#    3. Leave everything else as-is unless you know you need to change it
#
#  No Python knowledge required. Just edit the values after the "=".
# ============================================================

# === REQUIRED — you MUST fill these in ===

# Your bot's secret token. Get it from @BotFather on Telegram (/newbot).
TELEGRAM_BOT_TOKEN="paste-your-bot-token-here"

# Your personal Telegram numeric ID (you become the Owner).
# Get it from @userinfobot on Telegram.
TELEGRAM_OWNER_ID="paste-your-telegram-id-here"


# === OPTIONAL — leave these commented out unless your setup is different ===
#
# Everything below auto-detects based on YOUR computer's home folder.
# Only uncomment (remove the leading "#") and edit a line if your install
# is in a non-standard place.

# Path to the AI CLI executable.
# Default: <your-home>\AppData\Local\agy\bin\agy.exe
# CLI_PATH=C:\path\to\agy.exe

# Working directory the CLI runs in. Default: your home folder.
# CLI_WORKING_DIR=C:\path\to\workdir

# Where the CLI writes conversation transcripts.
# Default: <your-home>\.gemini\antigravity-cli\brain
# BRAIN_DIR=C:\path\to\brain

# Path to ffmpeg (only needed for voice-note transcription).
# Default: <your-home>\AGI-Brain\Tools\ffmpeg\ffmpeg.exe
# FFMPEG_PATH=C:\path\to\ffmpeg.exe


# === REAPER SETTINGS (safe defaults — usually no need to change) ===

# Kill the CLI after this many seconds of SILENCE (no output, no progress).
# Any activity resets the clock. 0 = never kill (wait forever).
IDLE_KILL_AFTER=600

# Hard ceiling: stop no matter what after this many seconds (catches stuck CLIs).
MAX_TOTAL_RUNTIME=3600


# === KIMI WEBBRIDGE (only needed for the /browse command) ===
KIMI_BRIDGE_URL=http://127.0.0.1:10086
